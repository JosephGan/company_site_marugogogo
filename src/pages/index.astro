---
import Layout from "../layouts/BaseLayout.astro";
import { text } from "../content/text.js";

const t = text["zh"];
---

<Layout
  title="首页"
  description="丸五株式会社 — 总部位于东京，专注来日医疗·养老·旅游咨询、跨境贸易、餐饮运营及农产品贸易服务。"
>
  <!-- Hero -->
  <section class="hero">
    <h1 data-i18n="home.heroTitle">{t.home.heroTitle}</h1>
    <p data-i18n="home.heroSubtitle">{t.home.heroSubtitle}</p>
    <div class="buttons">
      <a href="/contact" class="btn primary" data-i18n="home.buttons.contact">{t.home.buttons.contact}</a>
      <a href="/services" class="btn secondary" data-i18n="home.buttons.services">{t.home.buttons.services}</a>
    </div>
  </section>

  <!-- Company Introduction -->
  <section class="about-section">
    <div class="section-divider"></div>
    <h2 data-i18n="about.title">{t.about.title}</h2>
    {t.about.paragraphs.map((p, i) => (
      <p data-i18n={`about.paragraphs.${i}`}>{p}</p>
    ))}
  </section>
</Layout>

<script is:inline define:vars={{ text }}>
  function reRenderAbout(lang) {
    const t = text[lang];
    const aboutSection = document.querySelector('.about-section');
    if (!aboutSection || !t.about) return;
    const title = aboutSection.querySelector('[data-i18n="about.title"]');
    if (title) title.textContent = t.about.title;
    t.about.paragraphs.forEach((p, i) => {
      const el = aboutSection.querySelector(`[data-i18n="about.paragraphs.${i}"]`);
      if (el) el.textContent = p;
    });
  }

  document.addEventListener('langchange', (e) => reRenderAbout(e.detail.lang));
  reRenderAbout(localStorage.getItem('lang') || 'zh');
</script>
